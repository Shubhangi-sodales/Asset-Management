{
  "name": "asset_management",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.15.3",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4.13.0",
    "@sap/cds-dk": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds serve",
    "dev": "cds watch --profile hybrid"
  },
  "cds": {
    "requires": {
      "auth": "mocked",
      "db": {
        "kind": "hana"
      },
      "[production]": {
        "auth": "mocked"
      }
    },
    "sql": {
      "native_hana_associations": true
    },
    "server": {
      "body_parser": {
        "limit": "10mb"
      }
    }
  },
  "engines": {
    "node": ">=20"
  }
}