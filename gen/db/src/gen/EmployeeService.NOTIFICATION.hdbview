VIEW EmployeeService_NOTIFICATION AS SELECT
  NOTIFICATIONVIEW_0.ANTID,
  NOTIFICATIONVIEW_0.NTFID,
  NOTIFICATIONVIEW_0.USRID,
  NOTIFICATIONVIEW_0.MSG,
  NOTIFICATIONVIEW_0.ISRED,
  NOTIFICATIONVIEW_0.ISDEL,
  NOTIFICATIONVIEW_0.CRTDT,
  NOTIFICATIONVIEW_0.NOTYPE
FROM ASM_T_NOTIFICATIONVIEW AS NOTIFICATIONVIEW_0