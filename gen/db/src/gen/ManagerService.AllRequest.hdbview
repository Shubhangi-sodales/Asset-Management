VIEW ManagerService_AllRequest AS SELECT
  ALLREQUESTS_0.ASRID,
  ALLREQUESTS_0.REQID,
  ALLREQUESTS_0.USRID,
  user_1.NAME AS USERNAME,
  ALLREQUESTS_0.ASTID,
  ALLREQUESTS_0.CATID,
  category_2.CNAME AS CATNAME,
  ALLREQUESTS_0.RDATE,
  ALLREQUESTS_0.STAT,
  ALLREQUESTS_0.PRITY
FROM ((ASM_T_ALLREQUESTS AS ALLREQUESTS_0 LEFT JOIN ASM_M_USERVIEW AS user_1 ON user_1.USRID = ALLREQUESTS_0.USRID) LEFT JOIN ASM_M_ASSETCATGORY AS category_2 ON category_2.CATID = ALLREQUESTS_0.CATID)