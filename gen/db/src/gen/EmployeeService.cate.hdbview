VIEW EmployeeService_cate AS SELECT
  ASSETCATGORY_0.ACTID,
  ASSETCATGORY_0.CATID,
  ASSETCATGORY_0.CNAME,
  ASSETCATGORY_0.CDESC,
  ASSETCATGORY_0.STAT,
  ASSETCATGORY_0.ISDEL,
  ASSETCATGORY_0.CRTDT,
  ASSETCATGORY_0.CRTTM,
  ASSETCATGORY_0.CRTBY,
  ASSETCATGORY_0.CHNDT,
  ASSETCATGORY_0.CHNTM,
  ASSETCATGORY_0.CHNBY
FROM ASM_M_ASSETCATGORY AS ASSETCATGORY_0